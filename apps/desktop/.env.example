# RetroOasis Desktop — environment variable reference
#
# Copy this file to .env.local and adjust the values for your deployment.
# All variables are optional; the defaults below work for local development.

# ---------------------------------------------------------------------------
# Game API mode
#   mock    — bundled mock data, no network required (default)
#   backend — remote HTTP backend at VITE_BACKEND_URL
#   hybrid  — try backend first, fall back to mock on error
# ---------------------------------------------------------------------------
VITE_API_MODE=mock

# Backend base URL used when VITE_API_MODE is "backend" or "hybrid".
# Should point to the lobby-server HTTP interface.
VITE_BACKEND_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Lobby WebSocket URL
# The desktop app opens a WebSocket to this address for real-time lobby events.
# ---------------------------------------------------------------------------
VITE_WS_URL=ws://localhost:8080

# ---------------------------------------------------------------------------
# Launch API base URL
# Used by tauriLaunchEmulator fallback (non-Tauri / browser dev mode).
# Defaults to the HTTP equivalent of VITE_WS_URL when not set.
# ---------------------------------------------------------------------------
VITE_LAUNCH_API_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Community / social API base URL
# Used by community-service.ts, events-service.ts, stats-service.ts.
# Defaults to http://localhost:8080 when not set.
# ---------------------------------------------------------------------------
VITE_SERVER_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Relay host override
# When set, the UI uses this hostname/IP in the "relay endpoint" banner shown
# after a session starts (instead of the address surfaced by the server).
# Useful for deployments where the relay is behind a public hostname.
# ---------------------------------------------------------------------------
# VITE_RELAY_HOST=relay.example.com
