# RetroOasis Lobby Server — environment variable reference
#
# Copy this file to .env and adjust the values for your deployment.
# All variables are optional; the defaults below work for local development.

# ---------------------------------------------------------------------------
# Server port
# The WebSocket + HTTP lobby server listens on this port.
# ---------------------------------------------------------------------------
PORT=8080

# ---------------------------------------------------------------------------
# SQLite database path
# When set, the server persists rooms, sessions, friends, saves, and identity
# to a SQLite database at this path.  Leave unset to use in-memory storage.
# ---------------------------------------------------------------------------
# DB_PATH=./retro-oasis.db

# ---------------------------------------------------------------------------
# Relay configuration
# The TCP relay server allocates ports in [RELAY_PORT_MIN, RELAY_PORT_MAX]
# for netplay sessions.  RELAY_HOST is advertised to connecting clients.
# ---------------------------------------------------------------------------
RELAY_HOST=127.0.0.1
RELAY_PORT_MIN=9000
RELAY_PORT_MAX=9200

# Address the relay binds to (0.0.0.0 to accept connections on all interfaces)
# RELAY_BIND=0.0.0.0
